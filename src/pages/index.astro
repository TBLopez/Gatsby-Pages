---
import Layout from '../layouts/Layout.astro';
---

<Layout title="KINETIC_CIPHER | TONY KHAWAJA-LOPEZ">
  <!-- Top Navigation Shell -->
  <nav class="fixed top-0 w-full z-50 rounded-none bg-[#0e0e0e]/60 backdrop-blur-xl border-b border-[#c1fffe]/10 shadow-[0_0_20px_rgba(0,255,255,0.05)]">
    <div class="flex justify-between items-center w-full px-6 py-4 max-w-none">
      
      <!-- Mobile left side (Hamburger + Title) -->
      <div class="flex items-center gap-3 md:hidden">
        <span class="material-symbols-outlined text-[#00ffff]">menu</span>
        <h1 class="font-headline uppercase font-black text-xl text-[#00ffff] tracking-widest">KINETIC_CIPHER</h1>
      </div>

      <!-- Desktop left side (Title) -->
      <div class="hidden md:block text-2xl font-black tracking-tighter text-[#c1fffe] font-headline uppercase">
        KINETIC_CIPHER
      </div>

      <div class="hidden md:flex gap-8 items-center">
        <a class="font-headline uppercase tracking-tighter font-bold text-[#00ffff] border-b-2 border-[#00ffff] pb-1 transition-all duration-300" href="#">HOME</a>
        <a class="font-headline uppercase tracking-tighter font-bold text-[#c1fffe]/60 hover:text-[#00ffff] hover:bg-[#c1fffe]/5 transition-all duration-300" href="#about">ABOUT</a>
        <a class="font-headline uppercase tracking-tighter font-bold text-[#c1fffe]/60 hover:text-[#00ffff] hover:bg-[#c1fffe]/5 transition-all duration-300" href="#projects">PROJECTS</a>
        <a class="font-headline uppercase tracking-tighter font-bold text-[#c1fffe]/60 hover:text-[#00ffff] hover:bg-[#c1fffe]/5 transition-all duration-300" href="mailto:anthony.lopez2@g.austincc.edu">CONTACT</a>
      </div>
      <div class="hidden md:flex items-center gap-4">
        <button class="material-symbols-outlined text-[#00ffff] hover:scale-110 transition-transform">sensors</button>
        <div class="h-4 w-[1px] bg-outline-variant/30"></div>
        <div class="text-[10px] font-label tracking-[0.2em] text-secondary uppercase">System_Stable</div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="about" class="relative min-h-screen flex flex-col justify-center px-8 pt-20 overflow-hidden">
    <div class="absolute inset-0 grid-bg z-0"></div>
    <!-- Floating Geometric Primitives -->
    <div class="absolute top-1/4 right-[-5%] w-96 h-96 bg-primary/5 blur-[100px] rounded-full animate-pulse"></div>
    <div class="absolute bottom-1/4 left-[-5%] w-80 h-80 bg-secondary/5 blur-[100px] rounded-full animate-pulse object-cover" style="animation-duration: 4s;"></div>
    
    <div class="relative z-10 max-w-6xl mx-auto w-full grid md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 bg-surface-container-highest border-l-2 border-primary mb-6 shadow-md hover:shadow-primary/20 transition-all duration-300">
          <span class="material-symbols-outlined text-primary text-sm">security</span>
          <span class="text-[10px] font-label tracking-widest uppercase text-on-surface-variant">Active Threat Intelligence Vector</span>
        </div>
        
        <h1 class="font-headline text-6xl md:text-8xl font-black tracking-tighter uppercase leading-none mb-8 transition-transform hover:scale-[1.01] duration-500">
          ARCHITECTING <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">DIGITAL FORTRESSES</span>
        </h1>
        
        <p class="text-lg md:text-xl text-on-surface-variant max-w-2xl mb-12 border-l border-outline-variant/30 pl-6 leading-relaxed hover:border-primary transition-colors duration-500">
          Tony Khawaja-Lopez combines offensive depth with defensive structural integrity to engineer high-fidelity security ecosystems. Advanced persistent threat simulation and hardened infrastructure design.
        </p>
        
        <div class="flex flex-wrap gap-4">
          <a href="#projects" class="bg-primary-container text-on-primary-container px-10 py-4 font-headline font-bold uppercase tracking-tighter hover:shadow-[0_0_30px_rgba(0,255,255,0.3)] transition-all active:scale-95 inline-block cursor-pointer">
            Initiate Protocol_
          </a>
          <a href="mailto:anthony.lopez2@g.austincc.edu" class="border border-secondary/30 text-secondary px-10 py-4 font-headline font-bold uppercase tracking-tighter hover:bg-secondary/10 transition-all cursor-pointer">
            Technical_Briefing
          </a>
        </div>
      </div>
      
      <div class="md:col-span-4 hidden md:block">
        <div class="glass-panel border-r-4 border-primary p-6 relative hover:border-r-8 transition-all duration-300 ease-in-out">
          <div class="absolute -top-4 -left-4 w-8 h-8 border-t-2 border-l-2 border-primary"></div>
          <div class="space-y-4 font-label text-[11px] text-primary/70">
            <div class="flex justify-between items-center border-b border-outline-variant/20 pb-2">
              <span>OPERATOR:</span>
              <span class="text-on-surface">T_KHAWAJA_LOPEZ</span>
            </div>
            <div class="flex justify-between items-center border-b border-outline-variant/20 pb-2">
              <span>STATUS:</span>
              <span class="text-primary flex items-center gap-1">
                <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
                ENCRYPTED
              </span>
            </div>
            <div class="flex justify-between items-center border-b border-outline-variant/20 pb-2">
              <span>LOCATION:</span>
              <span class="text-on-surface">NODE_09 // GLOBAL</span>
            </div>
            <div class="mt-8">
              <div class="bg-surface-container-lowest p-4 font-mono text-xs leading-tight hover:shadow-[0_0_10px_rgba(0,255,255,0.1)] transition-all">
                <p class="text-secondary">&gt; boot --sys_kernel</p>
                <p class="text-on-surface-variant">&gt;&gt; initialising red_team.sh</p>
                <p class="text-on-surface-variant">&gt;&gt; bypass_firewall [OK]</p>
                <p class="text-on-surface-variant">&gt;&gt; injecting_payload [98%]</p>
                <p class="text-primary mt-2 animate-pulse">ACCESS_GRANTED_</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Services / Initial Projects -->
  <section id="projects" class="py-24 px-8 bg-surface-container-low relative">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
        <div>
          <h2 class="font-headline text-4xl md:text-5xl font-bold uppercase tracking-tighter">Academic Directives</h2>
          <p class="text-secondary font-label tracking-widest mt-2">STRATEGIC OFFENSIVE OPERATIONS</p>
        </div>
        <div class="text-right font-label text-xs text-on-surface-variant uppercase tracking-widest">
          Available for Remote Deployment / 2024
        </div>
      </div>
      
      <div class="grid md:grid-cols-2 gap-px bg-outline-variant/10">
        <!-- Cybersecurity Capstone Project -->
        <a href="/projects/Cybersecurity Capstone Project.pdf" target="_blank" class="block bg-surface p-12 group hover:bg-surface-container-highest hover:-translate-y-1 transition-all duration-500">
          <span class="material-symbols-outlined text-5xl text-primary mb-8 group-hover:rotate-12 transition-transform duration-500" data-weight="fill">radar</span>
          <h3 class="font-headline text-3xl font-bold mb-4 uppercase tracking-tighter text-on-surface group-hover:text-primary transition-colors">Cybersecurity Capstone Project</h3>
          <p class="text-on-surface-variant leading-relaxed mb-8">Full-spectrum adversary simulation designed to challenge detection and response capabilities across physical, social, and digital layers.</p>
          <ul class="space-y-3 font-label text-sm uppercase tracking-wider text-primary/80">
            <li class="flex items-center gap-2 group-hover:translate-x-2 transition-transform duration-300"><span class="w-1.5 h-1.5 bg-primary pulse-indicator"></span> Technical Writing</li>
            <li class="flex items-center gap-2 group-hover:translate-x-2 transition-transform duration-300 delay-75"><span class="w-1.5 h-1.5 bg-primary"></span> Deep Analysis</li>
            <li class="flex items-center gap-2 group-hover:translate-x-2 transition-transform duration-300 delay-150"><span class="w-1.5 h-1.5 bg-primary"></span> Capstone Deliverable</li>
          </ul>
        </a>

        <!-- IT 101 Executive Presentation -->
        <a href="/projects/IT 101 Executive Presentation.pdf" target="_blank" class="block bg-surface p-12 group hover:bg-surface-container-highest hover:-translate-y-1 transition-all duration-500 border-l border-outline-variant/10">
          <span class="material-symbols-outlined text-5xl text-secondary mb-8 group-hover:-rotate-12 transition-transform duration-500" data-weight="fill">target</span>
          <h3 class="font-headline text-3xl font-bold mb-4 uppercase tracking-tighter text-on-surface group-hover:text-secondary transition-colors">IT 101 Executive Presentation</h3>
          <p class="text-on-surface-variant leading-relaxed mb-8">Strategic presentation of critical technical assessments identifying key IT infrastructure challenges for executive leadership.</p>
          <ul class="space-y-3 font-label text-sm uppercase tracking-wider text-secondary/80">
            <li class="flex items-center gap-2 group-hover:translate-x-2 transition-transform duration-300"><span class="w-1.5 h-1.5 bg-secondary pulse-indicator"></span> Executive Briefing</li>
            <li class="flex items-center gap-2 group-hover:translate-x-2 transition-transform duration-300 delay-75"><span class="w-1.5 h-1.5 bg-secondary"></span> Cloud Configuration Audit</li>
            <li class="flex items-center gap-2 group-hover:translate-x-2 transition-transform duration-300 delay-150"><span class="w-1.5 h-1.5 bg-secondary"></span> Threat Modeling</li>
          </ul>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Operations (Bento Grid) -->
  <section class="py-24 px-8 overflow-hidden">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-headline text-4xl md:text-5xl font-bold uppercase tracking-tighter mb-16">Active Operations</h2>
      
      <div class="grid md:grid-cols-12 md:grid-rows-2 gap-6 h-auto md:h-[600px]">
        
        <!-- APT 28 Presentation -->
        <a href="/projects/APT 28 Presentation.pdf" target="_blank" class="block md:col-span-7 md:row-span-2 relative group overflow-hidden bg-surface-container-highest border-t border-primary/20 hover:border-primary transition-colors duration-500">
          <img alt="Cybersecurity command center with blue data screens" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-50 group-hover:scale-105 transition-all duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCIUzQFS7_5xlma7pwYhJLlIBWCbLW9UZbVokxFu1mElgQlzzDx4_UdiV1rrns5ATGdhGBvPFmx8OAJRScxZSF0Nf_Cdir8fgLAVobBiyEZRGJnPq8bG-XXhitphNCtIFHbCxVcouwXa_h5bjwaxPKzQvX1onWqguksBEroDLSAywgsnRP9Vk3cNfxq3VMsufgf8wWBVdtdNHtQiB3KmKqojvB-rtLUz9h5XW0fm_qhCqUVgTW88oBtPDvtNyCKuSD05sUIYcINDL8t"/>
          <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-10 transform group-hover:translate-y-[-10px] transition-transform duration-500">
            <div class="bg-primary text-on-primary-container text-[10px] font-label font-bold tracking-widest px-2 py-1 mb-4 inline-block uppercase">Advanced Persistent Threat // FANCY BEAR</div>
            <h3 class="font-headline text-4xl font-bold uppercase tracking-tighter text-white group-hover:text-primary transition-colors">APT 28 Presentation</h3>
            <p class="text-on-surface-variant max-w-md mt-4 text-sm group-hover:text-white transition-colors delay-100">Automated mitigation system for sophisticated DDoS and injection vectors. Deep dive analysis of Russian GRU-affiliated threat actor tactics, techniques, and procedures (TTPs).</p>
          </div>
        </a>

        <!-- APT 41 Attack Case Study -->
        <a href="/projects/APT 41 Attack Case Study.pdf" target="_blank" class="block md:col-span-5 md:row-span-1 relative group overflow-hidden bg-surface-container-high border-r border-secondary/20 hover:border-secondary transition-colors duration-500">
          <img alt="Abstract neural network glow" class="absolute inset-0 w-full h-full object-cover opacity-20 group-hover:opacity-40 group-hover:scale-110 transition-all duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBRWxq6DQEsmk0HZgyjB1Z7Zz9GJIrBq-fdPB_h4X7wEHRj7ksAe4CgGgGqUADei3VUhcDLE0xuvtmP8rtriineKM7_N9olsWo9EpphXsWh-NiY35N3xEjrVUjfMGaW-I1XrMSI5Y1jx3CK2UB8P9Z2cOnAlHjnZS2W-k6_pV06p7WZe-2gDHxYYaaq00dpiRru_P7JKX1SzScW-w7uRJERg50SuP_AzX6a6EpLiobocNycdVEkJTbmY2-K0Gch_sK1g3DjmGgxfrGc"/>
          <div class="relative p-8 h-full flex flex-col justify-end transform group-hover:translate-x-2 transition-transform duration-500">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-2 h-2 bg-secondary rounded-full animate-pulse"></span>
              <span class="text-secondary font-label text-[10px] uppercase tracking-widest">State Actor // WICKED PANDA</span>
            </div>
            <h3 class="font-headline text-2xl font-bold uppercase tracking-tighter text-on-surface group-hover:text-secondary transition-colors">APT 41 Case Study</h3>
            <p class="text-on-surface-variant text-xs mt-2 group-hover:text-white transition-colors delay-100">Machine learning cluster for predicting lateral movement in zero-trust environments. Comprehensive intelligence breakdown of suspected Chinese state-sponsored cyber espionage operations.</p>
          </div>
        </a>

        <!-- Technical Stats -->
        <div class="md:col-span-5 md:row-span-1 bg-surface-container-lowest p-8 flex flex-col justify-between border-b border-outline-variant/20 hover:bg-surface-container-low transition-colors duration-[1s]">
          <div class="grid grid-cols-2 gap-8">
            <div>
              <div class="text-3xl font-headline font-black text-primary hover:text-white transition-colors cursor-default">48.2k</div>
              <div class="text-[10px] font-label text-on-surface-variant uppercase tracking-widest mt-1 group-hover:text-primary">Threats Blocked</div>
            </div>
            <div>
              <div class="text-3xl font-headline font-black text-secondary hover:text-white transition-colors cursor-default">0.03ms</div>
              <div class="text-[10px] font-label text-on-surface-variant uppercase tracking-widest mt-1 group-hover:text-secondary">Response Latency</div>
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-outline-variant/10">
            <div class="flex justify-between items-center mb-2">
              <span class="text-[10px] font-label text-on-surface-variant uppercase">Network Load</span>
              <span class="text-[10px] font-label text-primary animate-pulse">Stable</span>
            </div>
            <div class="h-1 bg-surface-container-highest w-full overflow-hidden">
              <div class="h-full bg-primary w-[74%] transform origin-left hover:scale-x-110 transition-transform duration-1000"></div>
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-[#050505] w-full border-t border-[#262626] rounded-none">
    <div class="flex flex-col md:flex-row justify-between items-center w-full px-8 py-12 gap-4">
      <div class="flex flex-col items-center md:items-start gap-2 group">
        <div class="text-sm font-bold text-[#00ffff] font-headline tracking-tighter uppercase group-hover:text-secondary transition-colors">KINETIC_CIPHER</div>
        <div class="text-[10px] font-['Space_Grotesk'] tracking-widest uppercase text-[#262626] group-hover:text-outline transition-colors">© 2024 TONY KHAWAJA-LOPEZ. SYSTEM_STABLE_V2.0.4</div>
      </div>
      <div class="flex gap-8">
        <a class="font-['Space_Grotesk'] text-[10px] tracking-widest uppercase text-[#262626] hover:text-[#d873ff] hover:scale-110 transition-all duration-300" href="https://github.com/TBLopez" target="_blank">GITHUB</a>
        <a class="font-['Space_Grotesk'] text-[10px] tracking-widest uppercase text-[#262626] hover:text-[#d873ff] hover:scale-110 transition-all duration-300" href="https://www.linkedin.com/in/techtony/" target="_blank">LINKEDIN</a>
        <a class="font-['Space_Grotesk'] text-[10px] tracking-widest uppercase text-[#262626] hover:text-[#d873ff] hover:scale-110 transition-all duration-300" href="#">TERMINAL</a>
      </div>
      <div class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <span class="w-1 h-1 bg-[#00ffff] rounded-full animate-ping"></span>
        <span class="text-[10px] font-label text-primary/40 tracking-[0.3em]">SECURE_CONNECTION_ESTABLISHED</span>
      </div>
    </div>
  </footer>

  <!-- BottomNavBar (Mobile Only) -->
  <nav class="md:hidden fixed bottom-0 left-0 w-full glass-panel flex justify-around items-center px-4 py-3 z-50 border-t border-white/5 bg-[#0e0e0e]/90 pb-safe">
    <div class="flex flex-col items-center text-[#c1fffe] drop-shadow-[0_0_8px_rgba(0,255,255,0.8)]">
      <span class="material-symbols-outlined text-2xl">terminal</span>
      <span class="font-label text-[8px] tracking-widest mt-1">TERMINAL</span>
    </div>
    <div class="flex flex-col items-center text-outline">
      <span class="material-symbols-outlined text-2xl">lock</span>
      <span class="font-label text-[8px] tracking-widest mt-1 uppercase">ENCRYPT</span>
    </div>
    <a href="#projects" class="flex flex-col items-center text-outline hover:text-primary transition-colors">
      <span class="material-symbols-outlined text-2xl">database</span>
      <span class="font-label text-[8px] tracking-widest mt-1 uppercase">ARCHIVE</span>
    </a>
    <a href="#about" class="flex flex-col items-center text-outline hover:text-primary transition-colors">
      <span class="material-symbols-outlined text-2xl">person</span>
      <span class="font-label text-[8px] tracking-widest mt-1 uppercase">OPERATOR</span>
    </a>
  </nav>
</Layout>
