---
import Layout from '../layouts/Layout.astro';
import TerminalHeader from '../components/TerminalHeader.astro';
import TerminalSidebar from '../components/TerminalSidebar.astro';
import TerminalFooter from '../components/TerminalFooter.astro';
import WelcomeBanner from '../components/WelcomeBanner.astro';
import { Client } from '@notionhq/client';
import type { NotionProject } from '../scripts/terminal';

// Notion SDK v5 renamed `databases.query` to `dataSources.query`.
// Accept either env var name so existing deployments keep working.
const notionDataSourceId =
  import.meta.env.NOTION_DATA_SOURCE_ID || import.meta.env.NOTION_DATABASE_ID;
const notionConnected = !!(import.meta.env.NOTION_API_KEY && notionDataSourceId);

let notionProjects: NotionProject[] = [];

if (notionConnected) {
  try {
    const notion = new Client({ auth: import.meta.env.NOTION_API_KEY });
    const response = await notion.dataSources.query({
      data_source_id: notionDataSourceId,
    });
    notionProjects = response.results.map((page: any) => {
      const nameProp = Object.values(page.properties).find(
        (p: any) => p.type === 'title',
      ) as any;
      const descProp = Object.values(page.properties).find(
        (p: any) => p.type === 'rich_text',
      ) as any;
      const urlProp = Object.values(page.properties).find(
        (p: any) => p.type === 'url',
      ) as any;
      const fileProp = Object.values(page.properties).find(
        (p: any) => p.type === 'files',
      ) as any;

      let finalUrl = '#';
      if (fileProp?.files?.length > 0) {
        const f = fileProp.files[0];
        finalUrl = f.file ? f.file.url : f.external ? f.external.url : '#';
      } else if (urlProp?.url) {
        finalUrl = urlProp.url;
      }

      return {
        id: page.id,
        title: nameProp?.title[0]?.plain_text || 'Untitled_Log',
        description: descProp?.rich_text[0]?.plain_text || 'No intel available.',
        url: finalUrl,
      };
    });
  } catch (error) {
    console.error('Notion Connection Error:', error);
  }
}

const lastLogin = new Date()
  .toUTCString()
  .replace('GMT', 'UTC')
  .toUpperCase();
---

<Layout>
  <TerminalHeader />

  <div class="flex flex-1 overflow-hidden relative">
    <TerminalSidebar notionConnected={notionConnected} />

    <main
      id="terminal-output"
      class="flex-1 overflow-y-auto p-4 md:p-6 flex flex-col gap-4 font-body pb-40 relative z-30"
    >
      <WelcomeBanner lastLogin={lastLogin} />

      <div
        id="history-container"
        role="log"
        aria-live="polite"
        aria-atomic="false"
        aria-label="Terminal output"
        class="space-y-4"
      >
      </div>
      <div class="h-10"></div>
    </main>
  </div>

  <TerminalFooter />
</Layout>

<script>
  import { initTerminal } from '../scripts/terminal';
  const root = document.getElementById('cmd-input');
  if (root) {
    const dataEl = document.getElementById('terminal-data');
    const data = dataEl?.textContent
      ? JSON.parse(dataEl.textContent)
      : { notionProjects: [], notionConnected: false };
    initTerminal(data);
  }
</script>

<script
  id="terminal-data"
  type="application/json"
  is:inline
  set:html={JSON.stringify({ notionProjects, notionConnected })}
/>
