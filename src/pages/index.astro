---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tony KL | Home">
  <main class="container">
    <section class="hero">
      <div class="hero-text">
        <h1 class="hero-title">Tony Khawaja-Lopez</h1>
        <p class="hero-subtitle">Securing your digital world one click at a time. Cyber Threat Analyst & Security Specialist blending rigorous engineering with clean, accessible design.</p>
      </div>
    </section>

    <section id="projects">
      <h2>Featured Research & Work</h2>
      <div class="projects-grid">
        <div class="card">
          <h3>Flatiron Capstone</h3>
          <p>Summarization of a breach on an organization, root cause analysis, and recommended actions.</p>
          <a href="https://github.com/TBLopez/Projects/blob/293ff2c4905732e5eefaddcc1b04175a5110cdf4/Capstone%20Final%20Paper.pdf" target="_blank">Read Report →</a>
        </div>
        <div class="card">
          <h3>Executive Presentation</h3>
          <p>A presentation on the capstone project geared towards all executives dealing with a mock organization breach.</p>
          <a href="https://github.com/TBLopez/Projects/blob/293ff2c4905732e5eefaddcc1b04175a5110cdf4/ACME.pdf" target="_blank">View Docs →</a>
        </div>
        <div class="card">
          <h3>APT 28 'Fancy Bear'</h3>
          <p>Cyber Threat intelligence report covering TTPs, motivations, and famous attacks.</p>
          <a href="https://github.com/TBLopez/Projects/blob/3f48d87f4c44c8314e3af41228f9b851916f9d25/APT%2028.pdf" target="_blank">View Intel →</a>
        </div>
        <div class="card">
          <h3>APT 41 'Barium'</h3>
          <p>A practice on CKC and The Diamond Model from a blue team perspective.</p>
          <a href="https://github.com/TBLopez/Projects/blob/3f48d87f4c44c8314e3af41228f9b851916f9d25/APT%2041.pdf" target="_blank">View Intel →</a>
        </div>
      </div>
    </section>

    <section id="contact" style="margin-top: 6rem; padding-bottom: 4rem;">
      <h2>Connect</h2>
      <p style="margin-top: 1rem; color: var(--text-muted); font-size: 1.125rem;">
        Available for consulting and security infrastructure inquiries.<br/><br/>
        <a href="https://www.linkedin.com/in/techtony/" style="color: var(--primary); font-weight: bold; text-decoration: none; margin-right: 2rem;">LinkedIn</a> 
        <a href="https://github.com/TBLopez" style="color: var(--primary); font-weight: bold; text-decoration: none;">GitHub</a>
      </p>
    </section>
  </main>
</Layout>
