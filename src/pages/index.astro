<script is:inline define:vars={{ notionProjects, isNotionConnected }}>
  // Web Audio SFX Engine
  let audioCtx;
  const initAudio = () => {
      if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      if (audioCtx.state === 'suspended') audioCtx.resume();
  };
  
  const playSfx = (type) => {
      if (!audioCtx) return;
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      
      if (type === 'type') {
          osc.type = 'square';
          osc.frequency.setValueAtTime(800, audioCtx.currentTime);
          osc.frequency.exponentialRampToValueAtTime(1200, audioCtx.currentTime + 0.05);
          gain.gain.setValueAtTime(0.015, audioCtx.currentTime);
          gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.05);
          osc.start();
          osc.stop(audioCtx.currentTime + 0.05);
      } else if (type === 'enter') {
          osc.type = 'sawtooth';
          osc.frequency.setValueAtTime(400, audioCtx.currentTime);
          osc.frequency.exponentialRampToValueAtTime(100, audioCtx.currentTime + 0.15);
          gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
          gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.15);
          osc.start();
          osc.stop(audioCtx.currentTime + 0.15);
      } else if (type === 'done') {
          osc.type = 'sine';
          osc.frequency.setValueAtTime(1200, audioCtx.currentTime);
          gain.gain.setValueAtTime(0.02, audioCtx.currentTime);
          gain.gain.linearRampToValueAtTime(0, audioCtx.currentTime + 0.1);
          osc.start();
          osc.stop(audioCtx.currentTime + 0.1);
      }
  };

  document.addEventListener('keydown', initAudio, { once: true });
  document.addEventListener('click', initAudio, { once: true });

  const input = document.getElementById('cmd-input');
  const historyContainer = document.getElementById('history-container');
  const terminalOutput = document.getElementById('terminal-output');
  const terminalFooter = document.getElementById('terminal-footer');

  terminalFooter.addEventListener('click', () => {
    input.focus();
  });
  
  document.addEventListener('click', (e) => {
    if (!window.getSelection().toString() && e.target.tagName !== 'A' && e.target.tagName !== 'BUTTON') {
      setTimeout(() => input.focus(), 50);
    }
  });

  // Re-map internal files. If Database is connected, append CMS items!
  let systemFiles = {
    'capstone.pdf': { desc: 'IT Capstone Report', url: '/tonylopezcapstone.pdf' },
    'executive_pres.pdf': { desc: 'Executive Overview', url: '/IT_101_Executive_Presentation.pdf' },
    'apt28.pdf': { desc: 'Threat Actor 28 Profile', url: '/APT_28.pdf' },
    'apt41.pdf': { desc: 'Threat Actor 41 Profile', url: '/APT41_Case_Study.pdf' }
  };

  if (isNotionConnected && notionProjects.length > 0) {
      notionProjects.forEach(proj => {
          // Normalize title to a terminal friendly string without spaces
          const filename = proj.title.toLowerCase().replace(/\\s+/g, '_') + '.md';
          systemFiles[filename] = { desc: proj.description, url: proj.url };
      });
  }

  const commands = {
    'help': `
        <div class="text-[#00FF41] ml-4 mt-2">
            <div>AVAILABLE COMMANDS:</div>
            <div class="mt-2 grid grid-cols-[120px_1fr] gap-2 lg:gap-0 lg:grid-cols-[150px_1fr]">
                <span class="opacity-70">whoami</span><span>Display current operator info</span>
                <span class="opacity-70">pwd</span><span>Print working directory</span>
                <span class="opacity-70">date</span><span>Display system time</span>
                <span class="opacity-70">echo</span><span>Print arguments</span>
                <span class="opacity-70">ls</span><span>List available archives (projects/blogs)</span>
                <span class="opacity-70">cat [file]</span><span>Open archive inline (e.g., cat capstone.pdf)</span>
                <span class="opacity-70">clear</span><span>Clear terminal output</span>
            </div>
            <div class="mt-4 border-t border-[#3b4b37]/40 pt-2 opacity-50 text-[10px]">SOCIAL_LINKS: <a href="https://github.com/TBLopez" target="_blank" class="hover:text-white underline inline">github</a> | <a href="https://www.linkedin.com/in/techtony/" target="_blank" class="hover:text-white underline inline">linkedin</a></div>
            ${isNotionConnected ? '<div class="mt-1 opacity-50 text-[10px] text-[#00ff41]">DATABASE UPLINK ACTIVE (CMS ENABLED)</div>' : '<div class="mt-1 opacity-50 text-[10px] text-[#ffb4ab]">DATABASE UPLINK OFFLINE (NO CMS KEYS PROVIDED)</div>'}
        </div>
    `,
    'pwd': `
        <div class="text-[#00FF41] ml-4 mt-2">/home/operator/firefly/tony</div>
    `,
    'sudo': `
        <div class="text-[#ffb4ab] ml-4 mt-2 font-bold select-none uppercase animate-pulse">
           [!] SECURITY ALERT [!] <br/> 
           ACCESS DENIED: THIS INCIDENT WILL BE REPORTED.
        </div>
    `,
    'whoami': `
        <div class="text-[#00FF41] ml-4 mt-2">
            <span class="block">TONY LOPEZ // SECURITY_ANALYST</span>
            <span class="block opacity-70 mt-1">Specializing in security, penetration testing, and tactical development.</span>
        </div>
    `
  };

  const cmdForm = document.getElementById('cmd-form');

  // Recursive Typewriter Function
  function typewriteElement(el, speed = 10, callback) {
      const textNodes = [];
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null, false);
      let node;
      while(node = walker.nextNode()) {
          if (node.nodeValue.trim() !== '') textNodes.push(node);
      }
      if (textNodes.length === 0) {
          if (callback) callback();
          return;
      }
      
      const originalTexts = textNodes.map(n => n.nodeValue);
      textNodes.forEach(n => n.nodeValue = '');
      
      let nodeIndex = 0;
      let charIndex = 0;
      
      function typeChar() {
          if (nodeIndex >= textNodes.length) {
              playSfx('done');
              if (callback) callback();
              return;
          }
          
          const currentText = originalTexts[nodeIndex];
          if (charIndex < currentText.length) {
              textNodes[nodeIndex].nodeValue += currentText.charAt(charIndex);
              charIndex++;
              if (charIndex % 3 === 0) playSfx('type');
              
              const terminalOutput = document.getElementById('terminal-output');
              terminalOutput.scrollTop = terminalOutput.scrollHeight + 1000;
              setTimeout(typeChar, speed);
          } else {
              nodeIndex++;
              charIndex = 0;
              setTimeout(typeChar, speed);
          }
      }
      typeChar();
  }

  function handleCommand() {
      const cmd = input.value.trim();
      input.value = '';
      
      if (!cmd) return;
          
          if (cmd === 'clear') {
              historyContainer.innerHTML = '';
              return;
          }
          
          const promptHtml = `
              <div class="flex items-center gap-2 mt-4">
                  <span class="text-[#00FF41] font-bold">tony@firefly:~$</span>
                  <span class="text-white">${cmd}</span>
              </div>
          `;
          
          let responseHtml = '';
          const baseCmd = cmd.split(' ')[0].toLowerCase();
          
          if (commands[baseCmd]) {
              responseHtml = commands[baseCmd];
          } else if (baseCmd === 'echo') {
              const echoText = cmd.split(' ').slice(1).join(' ').replace(/</g, "&lt;").replace(/>/g, "&gt;");
              responseHtml = `<div class="text-white ml-4 mt-2 whitespace-pre-wrap">${echoText}</div>`;
          } else if (baseCmd === 'nmap') {
              const target = cmd.split(' ')[1] || '127.0.0.1';
              responseHtml = `
                  <div class="text-[#00FF41] ml-4 mt-2">
                      <div class="opacity-70">Starting Nmap 7.92 ( https://nmap.org ) at ${new Date().toISOString()}</div>
                      <div>Nmap scan report for ${target}</div>
                      <div>Host is up (0.00032s latency).</div>
                      <div class="mt-2 text-[#ffb4ab]">PORT      STATE    SERVICE</div>
                      <div class="text-white">22/tcp    <span class="text-[#ffb4ab]">filtered</span> ssh</div>
                      <div class="text-white">80/tcp    <span class="text-[#00FF41]">open</span>     http</div>
                      <div class="text-white">443/tcp   <span class="text-[#00FF41]">open</span>     https</div>
                      <div class="text-white">3306/tcp  <span class="text-[#ffb4ab]">filtered</span> mysql</div>
                      <div class="mt-2 text-[#ffb4ab] font-bold">[!] WARNING: UNSECURE PORT DETECTED. INITIATING PAYLOAD...</div>
                      <div class="text-white text-[10px] mt-1">[|||||||||||||||||||||||||||||||] 100% EXPLOIT SUCCESSFUL</div>
                      <div class="mt-2 text-[#00FF41] font-bold tracking-widest uppercase mb-4">SYSTEM COMPROMISED. ROOT ACCESS GRANTED.</div>
                  </div>
              `;
          } else if (baseCmd === 'date') {
              const d = new Date().toString();
              responseHtml = `<div class="text-[#00FF41] ml-4 mt-2">${d}</div>`;
          } else if (baseCmd === 'ls') {
              const fileList = Object.keys(systemFiles).map(f => `
                  <div class="col-span-1 border-l-2 border-[#3b4b37] pl-2 hover:border-[#00FF41] transition-colors">
                      <div class="text-[#99d688] font-bold">${f}</div>
                      <div class="text-[10px] text-white/50 truncate">${systemFiles[f].desc}</div>
                  </div>
              `).join('');
              responseHtml = `<div class="ml-4 mt-2 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">${fileList}</div>`;
          } else if (baseCmd === 'cat') {
              const file = cmd.split(' ')[1];
              if (systemFiles[file]) {
                  const dest = systemFiles[file].url && systemFiles[file].url !== '#' ? systemFiles[file].url : '#';
                  if (dest !== '#') {
                      responseHtml = `
                          <div class="ml-4 mt-4 w-full max-w-4xl bg-[#131313] border border-[#3b4b37] relative group animate-fade-in mb-8">
                              <div class="bg-[#00FF41] text-[#000000] text-[10px] font-bold px-2 py-1 flex justify-between items-center select-none uppercase tracking-widest">
                                  <span>VIEWER_MODULE // ${file}</span>
                                  <a href="${dest}" target="_blank" class="hover:text-white transition-colors cursor-pointer mr-2 flex items-center gap-1 bg-black/20 px-2 py-0.5 rounded">
                                      <span class="material-symbols-outlined text-[12px]">open_in_new</span> [NEW_SYS_WINDOW]
                                  </a>
                              </div>
                              <div class="w-full relative bg-[#000000] p-1">
                                  <iframe src="${dest}" class="w-full h-[60vh] border-none bg-[#ffffff] grayscale-[0.3] contrast-[1.1] filter transition-all duration-300 hover:grayscale-0" title="${file}"></iframe>
                              </div>
                          </div>
                      `;
                  } else {
                      responseHtml = `<div class="text-[#ffb4ab] ml-4 mt-2">cat: payload missing destination url</div>`;
                  }
              } else if (!file) {
                  responseHtml = `<div class="text-[#ffb4ab] ml-4 mt-2">cat: missing file operand</div>`;
              } else {
                  responseHtml = `<div class="text-[#ffb4ab] ml-4 mt-2">cat: ${file}: No such file or directory</div>`;
              }
          } else {
              responseHtml = `<div class="text-[#ffb4ab] ml-4 mt-2">bash: ${cmd}: command not found. Type 'help' for available commands.</div>`;
          }
          
          const entry = document.createElement('div');
          
          if (commands[baseCmd] || baseCmd === 'nmap' || baseCmd === 'echo' || baseCmd === 'date') {
              // Extract the user prompt and append it immediately
              const promptDiv = document.createElement('div');
              promptDiv.innerHTML = promptHtml;
              historyContainer.appendChild(promptDiv);
              
              // Create response wrapper and typewrite it
              const responseDiv = document.createElement('div');
              responseDiv.innerHTML = responseHtml;
              historyContainer.appendChild(responseDiv);
              
              playSfx('enter');
              input.disabled = true; // prevent typing while animating
              typewriteElement(responseDiv, 5, () => {
                  input.disabled = false;
                  input.focus();
              });
          } else {
              // Render instantly (for iframes and lists)
              entry.innerHTML = promptHtml + responseHtml;
              historyContainer.appendChild(entry);
              playSfx('enter');
              
              setTimeout(() => {
                  terminalOutput.scrollTo({ top: terminalOutput.scrollHeight + 1000, behavior: 'smooth' });
                  setTimeout(() => terminalOutput.scrollTop = terminalOutput.scrollHeight + 1000, 300);
              }, 50);
          }
  }

  cmdForm.addEventListener('submit', function(e) {
      e.preventDefault();
      handleCommand();
  });

  input.addEventListener('keydown', function(e) {
      initAudio();
      
      if (e.key === 'Tab') {
          e.preventDefault();
          const parts = input.value.split(' ');
          
          if (parts.length === 1) {
              const cmdPrefix = parts[0].toLowerCase();
              const availableCmds = Object.keys(commands).concat(['ls', 'cat', 'echo', 'date', 'pwd', 'nmap', 'clear']);
              const match = availableCmds.find(c => c.startsWith(cmdPrefix));
              if (match) input.value = match + ' ';
          } else if (parts.length === 2 && parts[0].toLowerCase() === 'cat') {
              const filePrefix = parts[1].toLowerCase();
              const match = Object.keys(systemFiles).find(f => f.startsWith(filePrefix));
              if (match) input.value = 'cat ' + match;
          }
      }
      
      if (e.key !== 'Enter' && e.key !== 'Tab') {
          playSfx('type');
      }

      if (e.key === 'Enter') {
          e.preventDefault();
          // We don't call handleCommand here because cmdForm submission will handle it securely.
          // e.preventDefault is enough.
      }
  });
</script>
