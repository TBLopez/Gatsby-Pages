---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tony Khawaja-Lopez — Security Analyst // Terminal Portfolio',
  description = 'Interactive terminal portfolio for Tony Khawaja-Lopez, a security analyst specializing in penetration testing and tactical development.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="generator" content={Astro.generator} />
  </head>
  <body
    class="bg-black text-primary-container font-body selection:bg-primary-container selection:text-black min-h-screen flex flex-col overflow-hidden m-0 p-0"
  >
    <a href="#cmd-input" class="skip-link">Skip to terminal input</a>
    <div class="scanline fixed inset-0 z-50 pointer-events-none" aria-hidden="true"></div>
    <slot />
  </body>
</html>
