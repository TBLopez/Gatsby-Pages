---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tony Khawaja-Lopez — Security Analyst // Terminal Portfolio',
  description = 'Interactive terminal portfolio for Tony Khawaja-Lopez, a security analyst specializing in penetration testing and tactical development.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta name="generator" content={Astro.generator} />
  </head>
  <body
    class="bg-black text-primary-container font-body selection:bg-primary-container selection:text-black min-h-dvh flex flex-col m-0 p-0"
  >
    <a href="#cmd-input" class="skip-link">Skip to terminal input</a>
    <canvas id="matrix-rain" aria-hidden="true"></canvas>
    <div class="scanline fixed inset-0 z-50 pointer-events-none" aria-hidden="true"></div>
    <slot />
    <div
      id="achievement-stack"
      aria-live="polite"
      aria-atomic="false"
      aria-label="Achievement notifications"
    >
    </div>
    <div id="boot-overlay" role="presentation" aria-hidden="true"></div>
  </body>
</html>
