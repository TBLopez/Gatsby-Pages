---
---

<footer
  id="terminal-footer"
  class="bg-black border-t border-outline-variant/40 p-4 w-full z-40 cursor-text shrink-0 pb-[max(1rem,env(safe-area-inset-bottom))]"
>
  <div
    class="max-w-7xl mx-auto flex items-center gap-3 w-full font-mono text-primary-container"
  >
    <label for="cmd-input" class="font-bold shrink-0" aria-hidden="true">
      tony@firefly:~$
    </label>
    <form
      id="cmd-form"
      class="relative flex-1 flex items-center whitespace-pre overflow-hidden m-0 p-0"
      autocomplete="off"
    >
      <input
        id="cmd-input"
        name="command"
        autocomplete="off"
        autofocus
        aria-label="Terminal command input"
        aria-describedby="cmd-hint"
        class="w-full bg-transparent outline-none border-none text-primary-container font-mono p-0 m-0 text-[16px] caret-[#00FF41] focus:ring-0"
        spellcheck="false"
        type="text"
      />
      <button type="submit" class="hidden">Submit</button>
    </form>
  </div>
  <span id="cmd-hint" class="sr-only">
    Type a command such as help, ls, whoami, cat [file], history, or contact.
    Use arrow up and down to cycle previous commands, Tab to complete, Ctrl+L
    to clear, Ctrl+C to cancel output.
  </span>
</footer>
