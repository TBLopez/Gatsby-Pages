---
type IconName =
  | 'minimize'
  | 'maximize'
  | 'close'
  | 'folder'
  | 'open_in_new'
  | 'menu';

interface Props {
  name: IconName;
  class?: string;
  size?: number;
  title?: string;
}

const { name, class: className = '', size = 18, title } = Astro.props;

// Material Design icon paths (Apache 2.0)
const paths: Record<IconName, string> = {
  minimize: 'M6 19h12v2H6z',
  maximize: 'M3 3h18v18H3V3zm2 4v12h14V7H5z',
  close:
    'M19 6.41 17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z',
  folder:
    'M10 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z',
  open_in_new:
    'M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z',
  menu: 'M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z',
};

---

{title ? (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="currentColor"
    class={className}
    role="img"
    aria-label={title}
  >
    <title>{title}</title>
    <path d={paths[name]}></path>
  </svg>
) : (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="currentColor"
    class={className}
    aria-hidden="true"
    focusable="false"
  >
    <path d={paths[name]}></path>
  </svg>
)}
